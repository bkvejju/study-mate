# StudyMate AI configuration (example)
# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# Real environment variables (exports) always take priority over this file.
#
# Providers: stub (default, no key needed) | openai | anthropic
#
# NOTE: the anthropic provider is locked to Claude Haiku 4.5 (claude-haiku-4-5);
# the *_AI_MODEL settings below are ignored for anthropic.
#
# There are TWO roles, each can use a different provider / key / model:
#   - explainer : the initial, token-heavy HTML generation (`study-mate explain`)
#   - panel     : the on-the-go study panel (summarise / explain / quiz / ...)
#
# Resolution order per setting: role-specific var first, then the shared one.

# ---- Shared fallback (used when a role-specific value is not set) -----------
STUDYMATE_AI_PROVIDER=stub
STUDYMATE_AI_API_KEY=
STUDYMATE_AI_MODEL=

# ---- Initial generation (explainers) ---------------------------------------
# e.g. a stronger model for the one-off, high-quality explainer pages.
STUDYMATE_EXPLAINER_AI_PROVIDER=
STUDYMATE_EXPLAINER_AI_API_KEY=
STUDYMATE_EXPLAINER_AI_MODEL=

# ---- On-the-go usage (study panel) -----------------------------------------
# e.g. a cheaper/faster model for frequent, small interactive requests.
STUDYMATE_PANEL_AI_PROVIDER=
STUDYMATE_PANEL_AI_API_KEY=
STUDYMATE_PANEL_AI_MODEL=

# ---- Token reduction (headroom) --------------------------------------------
# Optional: compress source text before sending it to the model to cut tokens.
# Requires the optional library:  uv sync --extra compress
# Best-effort — if not installed, these settings simply no-op.
# Truthy values: 1 / true / on / yes. Defaults to enabled.
STUDYMATE_COMPRESS=true
# Per-role overrides (fall back to STUDYMATE_COMPRESS):
STUDYMATE_EXPLAINER_COMPRESS=
STUDYMATE_PANEL_COMPRESS=

# ---- TLS / corporate proxy --------------------------------------------------
# Outbound HTTPS calls trust the OS keychain automatically (via `truststore`),
# which covers most corporate TLS-intercepting proxies. If verification still
# fails, point this at your corporate root CA PEM bundle:
STUDYMATE_CA_BUNDLE=
